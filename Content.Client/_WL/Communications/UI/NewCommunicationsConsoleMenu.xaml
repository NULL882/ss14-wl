<controls:FancyWindow xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
    Title="{Loc 'comms-console-menu-title'}"
    MinSize="550 420">

    <!-- Main Container -->
    <BoxContainer Orientation="Vertical"
        HorizontalExpand="False"
        VerticalExpand="True"
        Margin="6 6 6 5">

        <BoxContainer Orientation="Horizontal"
            HorizontalExpand="False"
            VerticalExpand="True"
            Margin="6 6 6 5">

            <BoxContainer Orientation="Vertical"
                HorizontalExpand="True"
                VerticalExpand="True">

                <BoxContainer Orientation="Horizontal">
                    <Label Text="{Loc 'wl-console-menu-alert'}"/>
                    <Control HorizontalExpand="True"/>
                    <OptionButton Name="AlertLevelButton"
                        Access="Public"
                        ToolTip="{Loc 'comms-console-menu-alert-level-button-tooltip'}"
                        HorizontalAlignment="Right"
                        MinWidth="100"/>
                </BoxContainer>

                <Control MinHeight="10"/>
                
                <BoxContainer Orientation="Horizontal">
                    <Label Text="{Loc 'wl-console-menu-emergency'}"/>
                    <Control HorizontalExpand="True"/>
                    <OptionButton Name="EmergencyButton"
                        Access="Public"
                        ToolTip="{Loc 'wl-console-menu-emergency-button-tooltip'}"
                        HorizontalAlignment="Right"
                        MinWidth="100"/>
                </BoxContainer>

                <Control VerticalExpand="True"/>
                <PanelContainer StyleClasses="LowDivider" />

                <BoxContainer Orientation="Vertical"
                    SeparationOverride="6"
                    Margin="0 2">

                    <BoxContainer Orientation="Horizontal">
                        <Label Text="{Loc 'wl-console-menu-shuttle'}"/>
                        <Control HorizontalExpand="True"/>
                        <RichTextLabel Name="CountdownLabel"/>
                    </BoxContainer>

                    <Button Name="EmergencyShuttleButton"
                        Access="Public"
                        Text="Placeholder Text"
                        ToolTip="{Loc 'comms-console-menu-emergency-shuttle-button-tooltip'}"/>
                </BoxContainer>

                <Control VerticalExpand="True"/>
                <PanelContainer StyleClasses="LowDivider" />


                <BoxContainer Orientation="Vertical">
                    <TextEdit Name="BroadcastInput"
                        VerticalExpand="True"
                        HorizontalExpand="True"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch"
                        MinHeight="70"/>

                    <Button Name="BroadcastButton"
                        Access="Public"
                        Text="{Loc 'comms-console-menu-broadcast-button'}"
                        ToolTip="{Loc 'comms-console-menu-broadcast-button-tooltip'}"/>
                </BoxContainer>
            </BoxContainer>

            <!--<PanelContainer StyleClasses="LowDivider" Margin="0 0 5 0"
                            MaxWidth="5" MinWidth="5"/>-->

            <BoxContainer Orientation="Vertical"
                HorizontalExpand="True"
                VerticalExpand="True"
                Margin="20 3 0 0"
                MinWidth="250">

                <TextEdit Name="MessageInput"
                    VerticalExpand="True"
                    HorizontalExpand="True"
                    VerticalAlignment="Stretch"
                    HorizontalAlignment="Stretch"
                    MinHeight="100"
                    MinWidth="250"/>

                <Button Name="AnnounceButton"
                    Access="Public"
                    Text="{Loc 'comms-console-menu-announcement-button'}"
                    ToolTip="{Loc 'comms-console-menu-announcement-button-tooltip'}"
                    Margin="0 0 1 0"/>
            </BoxContainer>
        </BoxContainer>

        <BoxContainer Orientation="Vertical">
            <PanelContainer StyleClasses="LowDivider" />
            <BoxContainer Orientation="Horizontal" Margin="10 2 5 0" VerticalAlignment="Bottom">
                <Label Text="{Loc 'wl-console-footer-left'}" StyleClasses="WindowFooterText" />
                <Label Text="{Loc 'wl-console-footer-right'}" StyleClasses="WindowFooterText"
                       HorizontalAlignment="Right" HorizontalExpand="True"  Margin="0 0 5 0" />
                <TextureRect StyleClasses="NTLogoDark" Stretch="KeepAspectCentered"
                             VerticalAlignment="Center" HorizontalAlignment="Right" SetSize="19 19"/>
            </BoxContainer>
        </BoxContainer>
        
    </BoxContainer>
</controls:FancyWindow>
